<h1>Threads (latest)</h1>
<table border="1" cellpadding="6" cellspacing="0">
  <thead>
    <tr>
      <th>ID</th>
      <th>Created</th>
      <th>Title</th>
      <th>User</th>
      <th>Category</th>
      <th>Summary</th>
    </tr>
  </thead>
  <tbody>
    <% @threads.each do |t| %>
      <tr>
        <td><%= link_to t.id, [:admin, t] %></td>
        <td><%= t.created_at&.strftime("%Y-%m-%d %H:%M:%S") %></td>
        <td><%= t.title %></td>
        <td><%= t.user&.name || t.user&.email %></td>
        <td><%= t.category&.slug %></td>
        <td><%= t.summary %></td>
      </tr>
    <% end %>
  </tbody>
</table>
